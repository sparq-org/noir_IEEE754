# IEEE 754 test suite cache (auto-downloaded)
.ieee754_test_cache/

# Berkeley TestFloat capture corpus (regenerated by
# scripts/regenerate_testfloat_corpus.sh; ~3 GB of testfloat_gen output)
.testfloat_cache/

# Noir build outputs
target/

# Generated test packages (created by scripts/generate_tests.py --packages)
test_packages/

# Legacy test module location (no longer used)
src/ieee754_tests/

scripts/__pycache__/
scripts/**/__pycache__/

# Empty Prover.toml created by `nargo test` runs
ieee754_unit_tests/Prover.toml
noir/lib/reference_tests/Prover.toml

# Lampe extraction output -- regenerated by `lampe` from a noir/lib/* dir.
# Never edited by hand. Re-run `lampe` after touching the underlying .nr.
noir/lib/*/lampe/

# Node.js / semantic-release
node_modules/
# package-lock.json

# OS files
.DS_Store

# Local Python venvs used for running scripts/test_*.py
.venv/
.pytest_cache/
