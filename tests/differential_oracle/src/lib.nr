#[test]
fn differential_oracle_f32_div() {
    // corner:0:div
    assert_eq((f32::new(0x00000000 as u32) / f32::new(0x00000000 as u32)).bits(), 0x7fc00000 as u32);
    // corner:1:div
    assert_eq((f32::new(0x00000000 as u32) / f32::new(0x80000000 as u32)).bits(), 0x7fc00000 as u32);
    // corner:2:div
    assert_eq((f32::new(0x00000000 as u32) / f32::new(0x7f800000 as u32)).bits(), 0x00000000 as u32);
    // corner:3:div
    assert_eq((f32::new(0x00000000 as u32) / f32::new(0xff800000 as u32)).bits(), 0x80000000 as u32);
    // corner:4:div
