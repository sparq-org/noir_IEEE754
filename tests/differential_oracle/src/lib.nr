#[test]
fn differential_oracle_f16_eq() {
    // corner:0
    assert_eq(f16::new(0x0000 as u16).eq(f16::new(0x0000 as u16)), true);
    // corner:1
    assert_eq(f16::new(0x0000 as u16).eq(f16::new(0x8000 as u16)), true);
    // corner:2
    assert_eq(f16::new(0x0000 as u16).eq(f16::new(0x7c00 as u16)), false);
    // corner:3
    assert_eq(f16::new(0x0000 as u16).eq(f16::new(0xfc00 as u16)), false);
    // corner:4
    assert_eq(f16::new(0x0000 as u16).eq(f16::new(0x0001 as u16)), false);
    // corner:5
    assert_eq(f16::new(0x0000 as u16).eq(f16::new(0x03ff as u16)), false);
