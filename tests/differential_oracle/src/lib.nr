#[test]
fn differential_oracle_f64_sub() {
    // corner:0:sub
    assert_eq((f64::new(0x0000000000000000 as u64) - f64::new(0x0000000000000000 as u64)).bits(), 0x0000000000000000 as u64);
    // corner:1:sub
    assert_eq((f64::new(0x0000000000000000 as u64) - f64::new(0x8000000000000000 as u64)).bits(), 0x0000000000000000 as u64);
    // corner:2:sub
    assert_eq((f64::new(0x0000000000000000 as u64) - f64::new(0x7ff0000000000000 as u64)).bits(), 0xfff0000000000000 as u64);
