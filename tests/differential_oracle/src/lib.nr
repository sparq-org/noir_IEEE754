#[test]
fn differential_oracle_f16_add() {
    // corner:0:add
    assert_eq((f16::new(0x0000 as u16) + f16::new(0x0000 as u16)).bits(), 0x0000 as u16);
    // corner:1:add
    assert_eq((f16::new(0x0000 as u16) + f16::new(0x8000 as u16)).bits(), 0x0000 as u16);
    // corner:2:add
    assert_eq((f16::new(0x0000 as u16) + f16::new(0x7c00 as u16)).bits(), 0x7c00 as u16);
    // corner:3:add
    assert_eq((f16::new(0x0000 as u16) + f16::new(0xfc00 as u16)).bits(), 0xfc00 as u16);
    // corner:4:add
    assert_eq((f16::new(0x0000 as u16) + f16::new(0x7e00 as u16)).bits(), 0x7e00 as u16);
    // corner:5:add
    assert_eq((f16::new(0x0000 as u16) + f16::new(0x0001 as u16)).bits(), 0x0001 as u16);
    // corner:6:add
    assert_eq((f16::new(0x0000 as u16) + f16::new(0x03ff as u16)).bits(), 0x03ff as u16);
    // corner:7:add
    assert_eq((f16::new(0x0000 as u16) + f16::new(0x0400 as u16)).bits(), 0x0400 as u16);
    // corner:8:add
    assert_eq((f16::new(0x0000 as u16) + f16::new(0x7bff as u16)).bits(), 0x7bff as u16);
    // corner:9:add
    assert_eq((f16::new(0x0000 as u16) + f16::new(0x3c00 as u16)).bits(), 0x3c00 as u16);
    // corner:10:add
    assert_eq((f16::new(0x0000 as u16) + f16::new(0x4000 as u16)).bits(), 0x4000 as u16);
    // corner:11:add
    assert_eq((f16::new(0x0000 as u16) + f16::new(0xbc00 as u16)).bits(), 0xbc00 as u16);
    // corner:12:add
    assert_eq((f16::new(0x0000 as u16) + f16::new(0x3800 as u16)).bits(), 0x3800 as u16);
    // corner:13:add
    assert_eq((f16::new(0x0000 as u16) + f16::new(0x3e00 as u16)).bits(), 0x3e00 as u16);
    // corner:14:add
    assert_eq((f16::new(0x0000 as u16) + f16::new(0x2400 as u16)).bits(), 0x2400 as u16);
    // corner:15:add
    assert_eq((f16::new(0x8000 as u16) + f16::new(0x0000 as u16)).bits(), 0x0000 as u16);
    // corner:16:add
    assert_eq((f16::new(0x8000 as u16) + f16::new(0x8000 as u16)).bits(), 0x8000 as u16);
    // corner:17:add
    assert_eq((f16::new(0x8000 as u16) + f16::new(0x7c00 as u16)).bits(), 0x7c00 as u16);
    // corner:18:add
    assert_eq((f16::new(0x8000 as u16) + f16::new(0xfc00 as u16)).bits(), 0xfc00 as u16);
    // corner:19:add
    assert_eq((f16::new(0x8000 as u16) + f16::new(0x7e00 as u16)).bits(), 0x7e00 as u16);
    // corner:20:add
    assert_eq((f16::new(0x8000 as u16) + f16::new(0x0001 as u16)).bits(), 0x0001 as u16);
    // corner:21:add
    assert_eq((f16::new(0x8000 as u16) + f16::new(0x03ff as u16)).bits(), 0x03ff as u16);
    // corner:22:add
    assert_eq((f16::new(0x8000 as u16) + f16::new(0x0400 as u16)).bits(), 0x0400 as u16);
    // corner:23:add
    assert_eq((f16::new(0x8000 as u16) + f16::new(0x7bff as u16)).bits(), 0x7bff as u16);
    // corner:24:add
    assert_eq((f16::new(0x8000 as u16) + f16::new(0x3c00 as u16)).bits(), 0x3c00 as u16);
    // corner:25:add
    assert_eq((f16::new(0x8000 as u16) + f16::new(0x4000 as u16)).bits(), 0x4000 as u16);
    // corner:26:add
    assert_eq((f16::new(0x8000 as u16) + f16::new(0xbc00 as u16)).bits(), 0xbc00 as u16);
    // corner:27:add
    assert_eq((f16::new(0x8000 as u16) + f16::new(0x3800 as u16)).bits(), 0x3800 as u16);
    // corner:28:add
    assert_eq((f16::new(0x8000 as u16) + f16::new(0x3e00 as u16)).bits(), 0x3e00 as u16);
    // corner:29:add
