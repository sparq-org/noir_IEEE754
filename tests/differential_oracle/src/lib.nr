#[test]
fn differential_oracle_f16_div() {
    // corner:0:div
    assert_eq((f16::new(0x0000 as u16) / f16::new(0x0000 as u16)).bits(), 0x7e00 as u16);
    // corner:1:div
    assert_eq((f16::new(0x0000 as u16) / f16::new(0x8000 as u16)).bits(), 0x7e00 as u16);
    // corner:2:div
    assert_eq((f16::new(0x0000 as u16) / f16::new(0x7c00 as u16)).bits(), 0x0000 as u16);
    // corner:3:div
    assert_eq((f16::new(0x0000 as u16) / f16::new(0xfc00 as u16)).bits(), 0x8000 as u16);
    // corner:4:div
    assert_eq((f16::new(0x0000 as u16) / f16::new(0x7e00 as u16)).bits(), 0x7e00 as u16);
    // corner:5:div
    assert_eq((f16::new(0x0000 as u16) / f16::new(0x0001 as u16)).bits(), 0x0000 as u16);
    // corner:6:div
    assert_eq((f16::new(0x0000 as u16) / f16::new(0x03ff as u16)).bits(), 0x0000 as u16);
    // corner:7:div
    assert_eq((f16::new(0x0000 as u16) / f16::new(0x0400 as u16)).bits(), 0x0000 as u16);
    // corner:8:div
    assert_eq((f16::new(0x0000 as u16) / f16::new(0x7bff as u16)).bits(), 0x0000 as u16);
    // corner:9:div
    assert_eq((f16::new(0x0000 as u16) / f16::new(0x3c00 as u16)).bits(), 0x0000 as u16);
    // corner:10:div
    assert_eq((f16::new(0x0000 as u16) / f16::new(0x4000 as u16)).bits(), 0x0000 as u16);
    // corner:11:div
    assert_eq((f16::new(0x0000 as u16) / f16::new(0xbc00 as u16)).bits(), 0x8000 as u16);
    // corner:12:div
    assert_eq((f16::new(0x0000 as u16) / f16::new(0x3800 as u16)).bits(), 0x0000 as u16);
    // corner:13:div
    assert_eq((f16::new(0x0000 as u16) / f16::new(0x3e00 as u16)).bits(), 0x0000 as u16);
    // corner:14:div
    assert_eq((f16::new(0x0000 as u16) / f16::new(0x2400 as u16)).bits(), 0x0000 as u16);
    // corner:15:div
    assert_eq((f16::new(0x8000 as u16) / f16::new(0x0000 as u16)).bits(), 0x7e00 as u16);
    // corner:16:div
    assert_eq((f16::new(0x8000 as u16) / f16::new(0x8000 as u16)).bits(), 0x7e00 as u16);
    // corner:17:div
    assert_eq((f16::new(0x8000 as u16) / f16::new(0x7c00 as u16)).bits(), 0x8000 as u16);
    // corner:18:div
    assert_eq((f16::new(0x8000 as u16) / f16::new(0xfc00 as u16)).bits(), 0x0000 as u16);
    // corner:19:div
    assert_eq((f16::new(0x8000 as u16) / f16::new(0x7e00 as u16)).bits(), 0x7e00 as u16);
    // corner:20:div
    assert_eq((f16::new(0x8000 as u16) / f16::new(0x0001 as u16)).bits(), 0x8000 as u16);
    // corner:21:div
    assert_eq((f16::new(0x8000 as u16) / f16::new(0x03ff as u16)).bits(), 0x8000 as u16);
    // corner:22:div
    assert_eq((f16::new(0x8000 as u16) / f16::new(0x0400 as u16)).bits(), 0x8000 as u16);
    // corner:23:div
    assert_eq((f16::new(0x8000 as u16) / f16::new(0x7bff as u16)).bits(), 0x8000 as u16);
    // corner:24:div
    assert_eq((f16::new(0x8000 as u16) / f16::new(0x3c00 as u16)).bits(), 0x8000 as u16);
    // corner:25:div
    assert_eq((f16::new(0x8000 as u16) / f16::new(0x4000 as u16)).bits(), 0x8000 as u16);
    // corner:26:div
    assert_eq((f16::new(0x8000 as u16) / f16::new(0xbc00 as u16)).bits(), 0x0000 as u16);
    // corner:27:div
    assert_eq((f16::new(0x8000 as u16) / f16::new(0x3800 as u16)).bits(), 0x8000 as u16);
    // corner:28:div
    assert_eq((f16::new(0x8000 as u16) / f16::new(0x3e00 as u16)).bits(), 0x8000 as u16);
    // corner:29:div
    assert_eq((f16::new(0x8000 as u16) / f16::new(0x2400 as u16)).bits(), 0x8000 as u16);
    // corner:30:div
    assert_eq((f16::new(0x7c00 as u16) / f16::new(0x0000 as u16)).bits(), 0x7c00 as u16);
