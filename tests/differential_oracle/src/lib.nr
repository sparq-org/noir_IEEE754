#[test]
fn differential_oracle_f64_eq() {
    // corner:0
    assert_eq(f64::new(0x0000000000000000 as u64).eq(f64::new(0x0000000000000000 as u64)), true);
    // corner:1
    assert_eq(f64::new(0x0000000000000000 as u64).eq(f64::new(0x8000000000000000 as u64)), true);
    // corner:2
    assert_eq(f64::new(0x0000000000000000 as u64).eq(f64::new(0x7ff0000000000000 as u64)), false);
    // corner:3
    assert_eq(f64::new(0x0000000000000000 as u64).eq(f64::new(0xfff0000000000000 as u64)), false);
    // corner:4
    assert_eq(f64::new(0x0000000000000000 as u64).eq(f64::new(0x0000000000000001 as u64)), false);
    // corner:5
    assert_eq(f64::new(0x0000000000000000 as u64).eq(f64::new(0x000fffffffffffff as u64)), false);
    // corner:6
    assert_eq(f64::new(0x0000000000000000 as u64).eq(f64::new(0x0010000000000000 as u64)), false);
    // corner:7
    assert_eq(f64::new(0x0000000000000000 as u64).eq(f64::new(0x7fefffffffffffff as u64)), false);
    // corner:8
    assert_eq(f64::new(0x0000000000000000 as u64).eq(f64::new(0x3ff0000000000000 as u64)), false);
    // corner:9
    assert_eq(f64::new(0x0000000000000000 as u64).eq(f64::new(0xbff0000000000000 as u64)), false);
    // corner:10
    assert_eq(f64::new(0x0000000000000000 as u64).eq(f64::new(0x7ff8000000000000 as u64)), false);
    // corner:11
    assert_eq(f64::new(0x0000000000000000 as u64).eq(f64::new(0x7ff0000000000001 as u64)), false);
    // corner:12
    assert_eq(f64::new(0x8000000000000000 as u64).eq(f64::new(0x0000000000000000 as u64)), true);
    // corner:13
    assert_eq(f64::new(0x8000000000000000 as u64).eq(f64::new(0x8000000000000000 as u64)), true);
    // corner:14
    assert_eq(f64::new(0x8000000000000000 as u64).eq(f64::new(0x7ff0000000000000 as u64)), false);
    // corner:15
    assert_eq(f64::new(0x8000000000000000 as u64).eq(f64::new(0xfff0000000000000 as u64)), false);
    // corner:16
    assert_eq(f64::new(0x8000000000000000 as u64).eq(f64::new(0x0000000000000001 as u64)), false);
    // corner:17
    assert_eq(f64::new(0x8000000000000000 as u64).eq(f64::new(0x000fffffffffffff as u64)), false);
    // corner:18
    assert_eq(f64::new(0x8000000000000000 as u64).eq(f64::new(0x0010000000000000 as u64)), false);
    // corner:19
    assert_eq(f64::new(0x8000000000000000 as u64).eq(f64::new(0x7fefffffffffffff as u64)), false);
    // corner:20
    assert_eq(f64::new(0x8000000000000000 as u64).eq(f64::new(0x3ff0000000000000 as u64)), false);
    // corner:21
    assert_eq(f64::new(0x8000000000000000 as u64).eq(f64::new(0xbff0000000000000 as u64)), false);
    // corner:22
    assert_eq(f64::new(0x8000000000000000 as u64).eq(f64::new(0x7ff8000000000000 as u64)), false);
    // corner:23
    assert_eq(f64::new(0x8000000000000000 as u64).eq(f64::new(0x7ff0000000000001 as u64)), false);
    // corner:24
    assert_eq(f64::new(0x7ff0000000000000 as u64).eq(f64::new(0x0000000000000000 as u64)), false);
    // corner:25
    assert_eq(f64::new(0x7ff0000000000000 as u64).eq(f64::new(0x8000000000000000 as u64)), false);
    // corner:26
    assert_eq(f64::new(0x7ff0000000000000 as u64).eq(f64::new(0x7ff0000000000000 as u64)), true);
    // corner:27
    assert_eq(f64::new(0x7ff0000000000000 as u64).eq(f64::new(0xfff0000000000000 as u64)), false);
    // corner:28
    assert_eq(f64::new(0x7ff0000000000000 as u64).eq(f64::new(0x0000000000000001 as u64)), false);
    // corner:29
    assert_eq(f64::new(0x7ff0000000000000 as u64).eq(f64::new(0x000fffffffffffff as u64)), false);
    // corner:30
    assert_eq(f64::new(0x7ff0000000000000 as u64).eq(f64::new(0x0010000000000000 as u64)), false);
    // corner:31
    assert_eq(f64::new(0x7ff0000000000000 as u64).eq(f64::new(0x7fefffffffffffff as u64)), false);
    // corner:32
    assert_eq(f64::new(0x7ff0000000000000 as u64).eq(f64::new(0x3ff0000000000000 as u64)), false);
    // corner:33
    assert_eq(f64::new(0x7ff0000000000000 as u64).eq(f64::new(0xbff0000000000000 as u64)), false);
    // corner:34
    assert_eq(f64::new(0x7ff0000000000000 as u64).eq(f64::new(0x7ff8000000000000 as u64)), false);
    // corner:35
    assert_eq(f64::new(0x7ff0000000000000 as u64).eq(f64::new(0x7ff0000000000001 as u64)), false);
    // corner:36
    assert_eq(f64::new(0xfff0000000000000 as u64).eq(f64::new(0x0000000000000000 as u64)), false);
    // corner:37
    assert_eq(f64::new(0xfff0000000000000 as u64).eq(f64::new(0x8000000000000000 as u64)), false);
    // corner:38
    assert_eq(f64::new(0xfff0000000000000 as u64).eq(f64::new(0x7ff0000000000000 as u64)), false);
    // corner:39
    assert_eq(f64::new(0xfff0000000000000 as u64).eq(f64::new(0xfff0000000000000 as u64)), true);
    // corner:40
    assert_eq(f64::new(0xfff0000000000000 as u64).eq(f64::new(0x0000000000000001 as u64)), false);
