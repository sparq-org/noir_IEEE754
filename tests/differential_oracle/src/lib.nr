#[test]
fn differential_oracle_f64_lt() {
    // corner:0
    assert_eq(f64::new(0x0000000000000000 as u64).lt(f64::new(0x0000000000000000 as u64)), false);
    // corner:1
    assert_eq(f64::new(0x0000000000000000 as u64).lt(f64::new(0x8000000000000000 as u64)), false);
    // corner:2
    assert_eq(f64::new(0x0000000000000000 as u64).lt(f64::new(0x7ff0000000000000 as u64)), true);
    // corner:3
    assert_eq(f64::new(0x0000000000000000 as u64).lt(f64::new(0xfff0000000000000 as u64)), false);
    // corner:4
    assert_eq(f64::new(0x0000000000000000 as u64).lt(f64::new(0x0000000000000001 as u64)), true);
    // corner:5
    assert_eq(f64::new(0x0000000000000000 as u64).lt(f64::new(0x000fffffffffffff as u64)), true);
    // corner:6
    assert_eq(f64::new(0x0000000000000000 as u64).lt(f64::new(0x0010000000000000 as u64)), true);
    // corner:7
    assert_eq(f64::new(0x0000000000000000 as u64).lt(f64::new(0x7fefffffffffffff as u64)), true);
    // corner:8
    assert_eq(f64::new(0x0000000000000000 as u64).lt(f64::new(0x3ff0000000000000 as u64)), true);
    // corner:9
    assert_eq(f64::new(0x0000000000000000 as u64).lt(f64::new(0xbff0000000000000 as u64)), false);
    // corner:10
    assert_eq(f64::new(0x0000000000000000 as u64).lt(f64::new(0x7ff8000000000000 as u64)), false);
    // corner:11
    assert_eq(f64::new(0x0000000000000000 as u64).lt(f64::new(0x7ff0000000000001 as u64)), false);
    // corner:12
    assert_eq(f64::new(0x8000000000000000 as u64).lt(f64::new(0x0000000000000000 as u64)), false);
    // corner:13
    assert_eq(f64::new(0x8000000000000000 as u64).lt(f64::new(0x8000000000000000 as u64)), false);
    // corner:14
    assert_eq(f64::new(0x8000000000000000 as u64).lt(f64::new(0x7ff0000000000000 as u64)), true);
    // corner:15
    assert_eq(f64::new(0x8000000000000000 as u64).lt(f64::new(0xfff0000000000000 as u64)), false);
    // corner:16
    assert_eq(f64::new(0x8000000000000000 as u64).lt(f64::new(0x0000000000000001 as u64)), true);
    // corner:17
    assert_eq(f64::new(0x8000000000000000 as u64).lt(f64::new(0x000fffffffffffff as u64)), true);
    // corner:18
