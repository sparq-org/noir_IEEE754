#[test]
fn differential_oracle_f16_le() {
    // corner:0
    assert_eq(f16::new(0x0000 as u16).le(f16::new(0x0000 as u16)), true);
    // corner:1
    assert_eq(f16::new(0x0000 as u16).le(f16::new(0x8000 as u16)), true);
    // corner:2
    assert_eq(f16::new(0x0000 as u16).le(f16::new(0x7c00 as u16)), true);
    // corner:3
    assert_eq(f16::new(0x0000 as u16).le(f16::new(0xfc00 as u16)), false);
    // corner:4
    assert_eq(f16::new(0x0000 as u16).le(f16::new(0x0001 as u16)), true);
    // corner:5
    assert_eq(f16::new(0x0000 as u16).le(f16::new(0x03ff as u16)), true);
    // corner:6
    assert_eq(f16::new(0x0000 as u16).le(f16::new(0x0400 as u16)), true);
    // corner:7
    assert_eq(f16::new(0x0000 as u16).le(f16::new(0x7bff as u16)), true);
    // corner:8
    assert_eq(f16::new(0x0000 as u16).le(f16::new(0x3c00 as u16)), true);
