#[test]
fn differential_oracle_f16_sub() {
    // corner:0:sub
    assert_eq((f16::new(0x0000 as u16) - f16::new(0x0000 as u16)).bits(), 0x0000 as u16);
    // corner:1:sub
    assert_eq((f16::new(0x0000 as u16) - f16::new(0x8000 as u16)).bits(), 0x0000 as u16);
