#[test]
fn differential_oracle_f64_div() {
    // corner:0:div
    assert_eq((f64::new(0x0000000000000000 as u64) / f64::new(0x0000000000000000 as u64)).bits(), 0x7ff8000000000000 as u64);
    // corner:1:div
    assert_eq((f64::new(0x0000000000000000 as u64) / f64::new(0x8000000000000000 as u64)).bits(), 0x7ff8000000000000 as u64);
