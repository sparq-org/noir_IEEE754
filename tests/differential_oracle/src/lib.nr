    assert_eq(f16::new(0x0000 as u16).lt(f16::new(0x03ff as u16)), true);
    // corner:6
    assert_eq(f16::new(0x0000 as u16).lt(f16::new(0x0400 as u16)), true);
    // corner:7
    assert_eq(f16::new(0x0000 as u16).lt(f16::new(0x7bff as u16)), true);
    // corner:8
    assert_eq(f16::new(0x0000 as u16).lt(f16::new(0x3c00 as u16)), true);
    // corner:9
    assert_eq(f16::new(0x0000 as u16).lt(f16::new(0xbc00 as u16)), false);
