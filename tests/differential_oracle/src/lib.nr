#[test]
fn differential_oracle_f32_eq() {
    // corner:0
    assert_eq(f32::new(0x00000000 as u32).eq(f32::new(0x00000000 as u32)), true);
    // corner:1
    assert_eq(f32::new(0x00000000 as u32).eq(f32::new(0x80000000 as u32)), true);
    // corner:2
    assert_eq(f32::new(0x00000000 as u32).eq(f32::new(0x7f800000 as u32)), false);
    // corner:3
    assert_eq(f32::new(0x00000000 as u32).eq(f32::new(0xff800000 as u32)), false);
    // corner:4
    assert_eq(f32::new(0x00000000 as u32).eq(f32::new(0x00000001 as u32)), false);
    // corner:5
    assert_eq(f32::new(0x00000000 as u32).eq(f32::new(0x007fffff as u32)), false);
    // corner:6
    assert_eq(f32::new(0x00000000 as u32).eq(f32::new(0x00800000 as u32)), false);
    // corner:7
    assert_eq(f32::new(0x00000000 as u32).eq(f32::new(0x7f7fffff as u32)), false);
    // corner:8
    assert_eq(f32::new(0x00000000 as u32).eq(f32::new(0x3f800000 as u32)), false);
    // corner:9
    assert_eq(f32::new(0x00000000 as u32).eq(f32::new(0xbf800000 as u32)), false);
