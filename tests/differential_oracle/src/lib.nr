    // corner:33:add
    assert_eq((f16::new(0x7c00 as u16) + f16::new(0xfc00 as u16)).bits(), 0x7e00 as u16);
    // corner:34:add
    assert_eq((f16::new(0x7c00 as u16) + f16::new(0x7e00 as u16)).bits(), 0x7e00 as u16);
    // corner:35:add
    assert_eq((f16::new(0x7c00 as u16) + f16::new(0x0001 as u16)).bits(), 0x7c00 as u16);
    // corner:36:add
    assert_eq((f16::new(0x7c00 as u16) + f16::new(0x03ff as u16)).bits(), 0x7c00 as u16);
    // corner:37:add
    assert_eq((f16::new(0x7c00 as u16) + f16::new(0x0400 as u16)).bits(), 0x7c00 as u16);
    // corner:38:add
    assert_eq((f16::new(0x7c00 as u16) + f16::new(0x7bff as u16)).bits(), 0x7c00 as u16);
    // corner:39:add
    assert_eq((f16::new(0x7c00 as u16) + f16::new(0x3c00 as u16)).bits(), 0x7c00 as u16);
    // corner:40:add
    assert_eq((f16::new(0x7c00 as u16) + f16::new(0x4000 as u16)).bits(), 0x7c00 as u16);
    // corner:41:add
    assert_eq((f16::new(0x7c00 as u16) + f16::new(0xbc00 as u16)).bits(), 0x7c00 as u16);
    // corner:42:add
    assert_eq((f16::new(0x7c00 as u16) + f16::new(0x3800 as u16)).bits(), 0x7c00 as u16);
    // corner:43:add
    assert_eq((f16::new(0x7c00 as u16) + f16::new(0x3e00 as u16)).bits(), 0x7c00 as u16);
    // corner:44:add
    assert_eq((f16::new(0x7c00 as u16) + f16::new(0x2400 as u16)).bits(), 0x7c00 as u16);
    // corner:45:add
