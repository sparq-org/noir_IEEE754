    // curated:6
    assert_eq(f128::from_field(2047 as Field).bits(), 0x4009ffc0000000000000000000000000 as u128);
    // curated:7
    assert_eq(f128::from_field(2049 as Field).bits(), 0x400a0020000000000000000000000000 as u128);
    // curated:8
